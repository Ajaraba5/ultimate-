{
  "name": "sistema-votacion-electoral-enterprise",
  "version": "3.0.0",
  "description": "Sistema de Votación Electoral Enterprise - La Fortaleza Digital de la Democracia",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Sistema listo para producción\" && exit 0",
    "setup-db": "node src/database/setup.js",
    "seed": "node src/database/seed.js",
    "seed:force": "node src/database/seed.js --force",
    "postinstall": "echo \"✅ Dependencias instaladas. Ejecuta 'npm run setup-db' para inicializar la base de datos\"",
    "deploy:heroku": "git push heroku main && heroku run npm run setup-db",
    "deploy:railway": "railway up",
    "health": "curl -f http://localhost:3000/health || exit 1"
  },
  "keywords": [
    "electoral",
    "voting",
    "democracy",
    "enterprise",
    "postgresql",
    "websocket",
    "real-time"
  ],
  "author": "Electoral Enterprise Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.6.1",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.1",
    "validator": "^13.11.0",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
