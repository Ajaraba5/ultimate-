# 🔒 SISTEMA DE VOTACIÓN ELECTORAL ENTERPRISE v3.0.0
# Configuración de Producción

# === BASE DE DATOS ===
# En Render usa DATABASE_URL (interna) y puedes omitir DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=electoral_system
DB_USER=postgres
DB_PASSWORD=tu_password_seguro_aqui

# === SEGURIDAD ===
JWT_SECRET=genera_un_secreto_super_seguro_de_64_caracteres_minimo_aqui
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12

# === SERVIDOR ===
PORT=3000
NODE_ENV=production
ALLOW_EXTERNAL_ACCESS=true
ALLOWED_ORIGINS=

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# === GOOGLE MAPS ===
GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps_aqui

# === BACKUP ===
BACKUP_INTERVAL_HOURS=6

# === SESIONES ===
SESSION_TIMEOUT_HOURS=12
